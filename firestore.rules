rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 輔助函式：檢查使用者是否已登入 (包含 Email 登入與匿名登入)
    function isSignedIn() {
      return request.auth != null;
    }
    
    // 代課系統白名單：須為 Email 登入且已驗證，且列於 subteach_allowed_users 且 enabled
    function isWhitelisted() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email_verified == true
        && exists(/databases/$(database)/documents/subteach_allowed_users/$(request.auth.token.email))
        && get(/databases/$(database)/documents/subteach_allowed_users/$(request.auth.token.email)).data.enabled == true;
    }
    function isSubteachAdmin() {
      return isWhitelisted()
        && get(/databases/$(database)/documents/subteach_allowed_users/$(request.auth.token.email)).data.role == 'admin';
    }
    // 僅依白名單文件判斷是否為 admin（不要求 email_verified），用於允許新增/編輯白名單，避免 token 延遲導致加入失敗
    function isSubteachAdminByDoc() {
      return request.auth != null
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/subteach_allowed_users/$(request.auth.token.email))
        && get(/databases/$(database)/documents/subteach_allowed_users/$(request.auth.token.email)).data.enabled == true
        && get(/databases/$(database)/documents/subteach_allowed_users/$(request.auth.token.email)).data.role == 'admin';
    }
    // 首次登入：尚未建立白名單 init 時，任一有 Email 的登入者暫可存取，由 App 寫入白名單（不要求 email_verified，避免 Google 登入後 token 延遲）
    function isFirstLoginBootstrap() {
      return request.auth != null
        && request.auth.token.email != null
        && !exists(/databases/$(database)/documents/system/subteach_whitelist_init);
    }
    // 指定管理員 Email，無條件通過（白名單遺失或 init 已存在時仍可登入）
    function isDesignatedSubteachAdmin() {
      return request.auth != null && request.auth.token.email == 'y.chengju@gmail.com';
    }
    function canAccessSubteach() {
      return isWhitelisted() || isFirstLoginBootstrap() || isDesignatedSubteachAdmin();
    }
    
    function isEduTrackAllowedUser() {
      return isSignedIn()
        && request.auth.token.email_verified == true
        && exists(/databases/$(database)/documents/edutrack_allowed_users/$(request.auth.token.email))
        && get(/databases/$(database)/documents/edutrack_allowed_users/$(request.auth.token.email)).data.enabled == true;
    }
    
    function isEduTrackAdmin() {
      return isEduTrackAllowedUser()
        && get(/databases/$(database)/documents/edutrack_allowed_users/$(request.auth.token.email)).data.role == 'admin';
    }
    
    // =========================================================
    // 代課系統 (Subteach)：白名單制；首次登入者自動取得權限並寫入白名單
    // =========================================================
    match /teachers/{teacherId} {
      allow read, write: if canAccessSubteach();
    }
    match /records/{recordId} {
      allow read, write: if canAccessSubteach();
    }
    match /overtimeRecords/{recordId} {
      allow read, write: if canAccessSubteach();
    }
    match /specialActivities/{activityId} {
      allow read, write: if canAccessSubteach();
    }
    match /salaryGrades/{gradeId} {
      allow read, write: if canAccessSubteach();
    }
    match /fixedOvertimeConfig/{configId} {
      allow read, write: if canAccessSubteach();
    }
    match /gradeEvents/{eventId} {
      allow read, write: if canAccessSubteach();
    }
    match /semesters/{semesterId} {
      allow read, write: if canAccessSubteach();
    }
    match /subPool/{teacherId} {
      allow read, write: if canAccessSubteach();
    }
    match /languagePayrolls/{payrollId} {
      allow read, write: if canAccessSubteach();
    }
    
    // system/settings 與 system/holidays 需要讓 EduTrack 讀取（點名單用學期起訖與放假日）
    match /system/{docId} {
      allow read: if canAccessSubteach() || (isEduTrackAllowedUser() && docId in ['settings', 'holidays']);
      allow write: if canAccessSubteach();
    }
    
    match /substituteApplications/{appId} {
      allow create: if true;
      allow read, update, delete: if canAccessSubteach();
    }
    match /publicBoard/{docId} {
      allow read: if true;
      allow write: if canAccessSubteach();
    }
    match /publicBoardApplications/{appId} {
      allow create: if true;
      allow read, update, delete: if canAccessSubteach();
    }
    match /teacherLeaveRequests/{requestId} {
      allow create: if true;
      allow read, update, delete: if canAccessSubteach();
    }
    match /publicTeacherSchedules/{teacherName} {
      allow read: if true;
      allow write: if canAccessSubteach();
    }
    match /subteach_allowed_users/{email} {
      allow read: if (isWhitelisted() || isFirstLoginBootstrap() || isDesignatedSubteachAdmin()) && (request.auth.token.email == email || isSubteachAdmin() || isSubteachAdminByDoc() || isDesignatedSubteachAdmin());
      allow create: if (isFirstLoginBootstrap() && request.auth.token.email == email) || isSubteachAdmin() || isSubteachAdminByDoc() || isDesignatedSubteachAdmin();
      allow update, delete: if isSubteachAdmin() || isSubteachAdminByDoc() || isDesignatedSubteachAdmin();
    }
    
    // =========================================================
    // 教學組事務管理系統 (EduTrack) - 外掛集合，前綴 edutrack_
    // =========================================================
    match /edutrack_courses/{id} {
      allow read, write: if isEduTrackAllowedUser();
    }
    match /edutrack_students/{id} {
      allow read, write: if isEduTrackAllowedUser();
    }
    match /edutrack_awards/{id} {
      allow read, write: if isEduTrackAllowedUser();
    }
    match /edutrack_vendors/{id} {
      allow read, write: if isEduTrackAllowedUser();
    }
    match /edutrack_archive/{id} {
      allow read, write: if isEduTrackAllowedUser();
    }
    match /edutrack_todos/{id} {
      allow read, write: if isEduTrackAllowedUser();
    }
    match /edutrack_exam_papers/{id} {
      allow read, write: if isEduTrackAllowedUser();
    }
    match /edutrack_exam_paper_folders/{id} {
      allow read, write: if isEduTrackAllowedUser();
    }
    match /edutrack_exam_paper_checks/{id} {
      allow read, write: if isEduTrackAllowedUser();
    }
    match /edutrack_language_elective/{id} {
      allow read, write: if isEduTrackAllowedUser();
    }
    match /edutrack_allowed_users/{email} {
      allow read: if isEduTrackAdmin() || (isSignedIn() && request.auth.token.email == email);
      allow create, update, delete: if isEduTrackAdmin();
    }
    
    // （保留）若未來改回用 edutrack_calendar_settings，也能存取
    match /edutrack_calendar_settings/{docId} {
      allow read, write: if isEduTrackAllowedUser();
    }
    
    // =========================================================
    // 預設規則
    // =========================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

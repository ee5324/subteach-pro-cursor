rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========== 既有系統：管理員與登入判斷 ==========
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'y.chengju@gmail.com';
    }
    function isAuth() {
      return request.auth != null;
    }

    // 系統設定：所有人可讀 (為了維護遮罩)，僅管理員可寫
    match /config/system {
      allow read: if true;
      allow write: if isAdmin();
    }
    // 學生名單：所有人可讀 (登入驗證用)，僅管理員可寫
    match /students/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    // 交易紀錄：學生可讀取自己的 (透過 query)，管理員可全讀寫
    match /transactions/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    // 獎品資訊：學生可 update 扣庫存，管理員可全權處理
    match /prizes/{docId} {
      allow read: if isAuth();
      allow update: if isAuth();
      allow write: if isAdmin();
    }
    // 分數提報：學生可新增，管理員可審核
    match /submissions/{docId} {
      allow create: if isAuth();
      allow read, update, delete: if isAdmin();
      allow read: if isAuth() && resource.data.studentName == request.query.studentName;
    }
    // 預約紀錄：學生可新增與讀取自己的，管理員可處理
    match /reservations/{docId} {
      allow create: if isAuth();
      allow read, update: if isAuth();
      allow delete: if isAdmin();
    }

    // ========== 代課系統 (Subteach)：白名單制 ==========
    // 須為 Email 登入且已驗證，且列於 subteach_allowed_users 且 enabled
    function isWhitelisted() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email_verified == true
        && exists(/databases/$(database)/documents/subteach_allowed_users/$(request.auth.token.email))
        && get(/databases/$(database)/documents/subteach_allowed_users/$(request.auth.token.email)).data.enabled == true;
    }
    function isSubteachAdmin() {
      return isWhitelisted()
        && get(/databases/$(database)/documents/subteach_allowed_users/$(request.auth.token.email)).data.role == 'admin';
    }

    match /teachers/{teacherId} {
      allow read, write: if isWhitelisted();
    }
    match /records/{recordId} {
      allow read, write: if isWhitelisted();
    }
    match /overtimeRecords/{recordId} {
      allow read, write: if isWhitelisted();
    }
    match /specialActivities/{activityId} {
      allow read, write: if isWhitelisted();
    }
    match /salaryGrades/{gradeId} {
      allow read, write: if isWhitelisted();
    }
    match /fixedOvertimeConfig/{configId} {
      allow read, write: if isWhitelisted();
    }
    match /gradeEvents/{eventId} {
      allow read, write: if isWhitelisted();
    }
    match /semesters/{semesterId} {
      allow read, write: if isWhitelisted();
    }
    match /subPool/{teacherId} {
      allow read, write: if isWhitelisted();
    }
    match /languagePayrolls/{payrollId} {
      allow read, write: if isWhitelisted();
    }
    // 代課系統專用 system 集合 (settings, holidays, metadata)，與既有 /config/system 不同
    match /system/{docId} {
      allow read, write: if isWhitelisted();
    }
    match /substituteApplications/{appId} {
      allow create: if true;
      allow read, update, delete: if isWhitelisted();
    }
    match /publicBoard/{docId} {
      allow read: if true;
      allow write: if isWhitelisted();
    }
    match /publicBoardApplications/{appId} {
      allow create: if true;
      allow read, update, delete: if isWhitelisted();
    }
    match /teacherLeaveRequests/{requestId} {
      allow create: if true;
      allow read, update, delete: if isWhitelisted();
    }
    match /publicTeacherSchedules/{teacherName} {
      allow read: if true;
      allow write: if isWhitelisted();
    }
    match /subteach_allowed_users/{email} {
      allow read: if isWhitelisted() && (request.auth.token.email == email || isSubteachAdmin());
      allow create, update, delete: if isSubteachAdmin();
    }
  }
}

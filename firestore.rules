rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 輔助函式：檢查使用者是否已登入 (包含 Email 登入與匿名登入)
    function isSignedIn() {
      return request.auth != null;
    }
    
    // 白名單文件 ID 與 App 寫入一致為小寫；Auth token 的 email 可能含大寫，路徑一律用 .lower() 對齊
    function subteachWhitelistEmailKey() {
      return request.auth.token.email == null
        ? ''
        : request.auth.token.email.lower();
    }
    // 代課系統白名單：須為 Email 登入且已驗證，且列於 subteach_allowed_users 且 enabled
    function isWhitelisted() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email_verified == true
        && exists(/databases/$(database)/documents/subteach_allowed_users/$(subteachWhitelistEmailKey()))
        && get(/databases/$(database)/documents/subteach_allowed_users/$(subteachWhitelistEmailKey())).data.enabled == true;
    }
    function isSubteachAdmin() {
      return isWhitelisted()
        && get(/databases/$(database)/documents/subteach_allowed_users/$(subteachWhitelistEmailKey())).data.role == 'admin';
    }
    // 僅依白名單文件判斷是否為 admin（不要求 email_verified），用於允許新增/編輯白名單，避免 token 延遲導致加入失敗
    function isSubteachAdminByDoc() {
      return request.auth != null
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/subteach_allowed_users/$(subteachWhitelistEmailKey()))
        && get(/databases/$(database)/documents/subteach_allowed_users/$(subteachWhitelistEmailKey())).data.enabled == true
        && get(/databases/$(database)/documents/subteach_allowed_users/$(subteachWhitelistEmailKey())).data.role == 'admin';
    }
    // 首次登入：尚未建立白名單 init 時，任一有 Email 的登入者暫可存取，由 App 寫入白名單（不要求 email_verified，避免 Google 登入後 token 延遲）
    function isFirstLoginBootstrap() {
      return request.auth != null
        && request.auth.token.email != null
        && !exists(/databases/$(database)/documents/system/subteach_whitelist_init);
    }
    // 指定管理員 Email，無條件通過（白名單遺失或 init 已存在時仍可登入）
    function isDesignatedSubteachAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() == 'y.chengju@gmail.com';
    }
    function canAccessSubteach() {
      return isWhitelisted() || isFirstLoginBootstrap() || isDesignatedSubteachAdmin();
    }
    
    function isEduTrackAllowedUser() {
      return isSignedIn()
        && request.auth.token.email_verified == true
        && exists(/databases/$(database)/documents/edutrack_allowed_users/$(request.auth.token.email))
        && get(/databases/$(database)/documents/edutrack_allowed_users/$(request.auth.token.email)).data.enabled == true;
    }
    
    function isEduTrackAdmin() {
      return isEduTrackAllowedUser()
        && get(/databases/$(database)/documents/edutrack_allowed_users/$(request.auth.token.email)).data.role == 'admin';
    }

    // 段考填報（導師）白名單：需登入且列於 exam_submit_allowed_users 且 enabled
    function isExamSubmitAllowedUser() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email_verified == true
        && exists(/databases/$(database)/documents/exam_submit_allowed_users/$(request.auth.token.email))
        && get(/databases/$(database)/documents/exam_submit_allowed_users/$(request.auth.token.email)).data.enabled == true;
    }

    // 取得活動的預設鎖定設定（找不到活動時，預設鎖定=true）
    function examCampaignLockedByDefault(campaignId) {
      return !exists(/databases/$(database)/documents/edutrack_exam_campaigns/$(campaignId))
        || get(/databases/$(database)/documents/edutrack_exam_campaigns/$(campaignId)).data.lockedByDefault == true;
    }

    // 段考填報公開模式：由 edutrack_exam_system/exam_awards.allowPublicSubmitNoLogin 控制
    function isExamPublicSubmitEnabled() {
      return exists(/databases/$(database)/documents/edutrack_exam_system/exam_awards)
        && get(/databases/$(database)/documents/edutrack_exam_system/exam_awards).data.allowPublicSubmitNoLogin == true;
    }
    
    // =========================================================
    // 代課系統 (Subteach)：白名單制；首次登入者自動取得權限並寫入白名單
    // =========================================================
    match /teachers/{teacherId} {
      allow read, write: if canAccessSubteach();
    }
    match /records/{recordId} {
      allow read, write: if canAccessSubteach();
    }
    match /overtimeRecords/{recordId} {
      allow read, write: if canAccessSubteach();
    }
    match /specialActivities/{activityId} {
      allow read, write: if canAccessSubteach();
    }
    match /salaryGrades/{gradeId} {
      allow read, write: if canAccessSubteach();
    }
    match /fixedOvertimeConfig/{configId} {
      allow read, write: if canAccessSubteach();
    }
    match /gradeEvents/{eventId} {
      allow read, write: if canAccessSubteach();
    }
    match /semesters/{semesterId} {
      allow read, write: if canAccessSubteach();
    }
    match /subPool/{teacherId} {
      allow read, write: if canAccessSubteach();
    }
    // 代課老師單日／每週固定「忙碌不接」紀錄（Subteach 專用；與 EduTrack／段考填報無涉）
    match /substituteBusyBlocks/{blockId} {
      allow read, write: if canAccessSubteach();
    }
    match /languagePayrolls/{payrollId} {
      allow read, write: if canAccessSubteach();
    }
    
    // system/settings 與 system/holidays 需要讓 EduTrack 讀取（點名單用學期起訖與放假日）
    match /system/{docId} {
      allow read: if canAccessSubteach() || (isEduTrackAllowedUser() && docId in ['settings', 'holidays']);
      allow write: if canAccessSubteach();
    }
    
    match /substituteApplications/{appId} {
      allow create: if true;
      allow read, update, delete: if canAccessSubteach();
    }
    match /publicBoard/{docId} {
      allow read: if true;
      allow write: if canAccessSubteach();
    }
    match /publicBoardApplications/{appId} {
      allow create: if true;
      allow read, update, delete: if canAccessSubteach();
    }
    match /teacherLeaveRequests/{requestId} {
      allow create: if true;
      allow read, update, delete: if canAccessSubteach();
    }
    match /publicTeacherSchedules/{teacherName} {
      allow read: if true;
      allow write: if canAccessSubteach();
    }
    // 代課老師自助週課表（#/sub-weekly）：App 同步寫入；公開讀（實際曝露欄位由 App 決定，例如末四碼）
    match /publicSubstituteSchedules/{teacherId} {
      allow read: if true;
      allow write: if canAccessSubteach();
    }
    // 代課週課表公開查詢（#/sub-weekly）瀏覽紀錄：未登入可寫入；僅代課系統管理員可讀
    match /substituteWeeklyLookupViews/{docId} {
      allow create: if request.resource.data.keys().hasOnly(['teacherId', 'teacherName', 'yearMonth', 'viewedAt', 'source'])
        && request.resource.data.source == 'sub-weekly'
        && request.resource.data.teacherId is string
        && request.resource.data.teacherId.size() > 0
        && request.resource.data.teacherId.size() <= 128
        && request.resource.data.teacherName is string
        && request.resource.data.teacherName.size() <= 100
        && request.resource.data.yearMonth is string
        && request.resource.data.yearMonth.matches('^\\d{4}-\\d{2}$');
      allow read: if isSubteachAdmin() || isSubteachAdminByDoc() || isDesignatedSubteachAdmin();
      allow update, delete: if false;
    }
    match /subteach_allowed_users/{email} {
      allow read: if (isWhitelisted() || isFirstLoginBootstrap() || isDesignatedSubteachAdmin()) && (request.auth.token.email.lower() == email.lower() || isSubteachAdmin() || isSubteachAdminByDoc() || isDesignatedSubteachAdmin());
      allow create: if (isFirstLoginBootstrap() && request.auth.token.email.lower() == email.lower()) || isSubteachAdmin() || isSubteachAdminByDoc() || isDesignatedSubteachAdmin();
      allow update, delete: if isSubteachAdmin() || isSubteachAdminByDoc() || isDesignatedSubteachAdmin();
    }

    // =========================================================
    // 段考填報（對外導師網站）
    // =========================================================
    match /exam_submit_allowed_users/{email} {
      // 允許使用者讀自己的白名單狀態；管理者可讀全部
      allow read: if (isSignedIn() && request.auth.token.email == email) || isEduTrackAdmin();
      // 僅教學組管理者可新增/修改/刪除
      allow create, update, delete: if isEduTrackAdmin();
    }
    
    // =========================================================
    // 教學組事務管理系統 (EduTrack) - 外掛集合，前綴 edutrack_
    // =========================================================
    match /edutrack_courses/{id} {
      allow read, write: if isEduTrackAllowedUser();
    }
    match /edutrack_students/{id} {
      allow read, write: if isEduTrackAllowedUser();
    }
    match /edutrack_awards/{id} {
      allow read, write: if isEduTrackAllowedUser();
    }
    match /edutrack_vendors/{id} {
      allow read, write: if isEduTrackAllowedUser();
    }
    match /edutrack_archive/{id} {
      allow read, write: if isEduTrackAllowedUser();
    }
    match /edutrack_todos/{id} {
      allow read, write: if isEduTrackAllowedUser();
    }
    match /edutrack_monthly_recurring_todos/{id} {
      allow read, write: if isEduTrackAllowedUser();
    }
    match /edutrack_exam_papers/{id} {
      allow read, write: if isEduTrackAllowedUser();
    }
    match /edutrack_exam_paper_folders/{id} {
      allow read, write: if isEduTrackAllowedUser();
    }
    match /edutrack_exam_paper_checks/{id} {
      allow read, write: if isEduTrackAllowedUser();
    }
    match /edutrack_language_elective/{id} {
      allow read: if isEduTrackAllowedUser() || isExamPublicSubmitEnabled();
      allow write: if isEduTrackAllowedUser();
    }
    // 語言選修學生主檔（B 方案）：權限與 edutrack_language_elective 相同，僅 EduTrack 白名單
    match /edutrack_language_elective_students/{id} {
      allow read: if isEduTrackAllowedUser() || isExamPublicSubmitEnabled();
      allow write: if isEduTrackAllowedUser();
    }
    // 段考提報：活動、獎項設定、提報資料
    // 活動列表／標題：對外進度頁需供匿名選段考（僅中繼資料；學生須另有權限）
    match /edutrack_exam_campaigns/{id} {
      allow read: if true;
      allow write: if isEduTrackAdmin();
    }
    match /edutrack_exam_system/{docId} {
      allow read: if isEduTrackAllowedUser() || isExamSubmitAllowedUser() || docId == 'exam_awards';
      allow write: if isEduTrackAdmin();
    }
    match /edutrack_exam_submissions/{id} {
      // 管理端與導師白名單可讀
      allow read: if isEduTrackAllowedUser() || isExamSubmitAllowedUser();
      // 導師送出：新建（預設鎖定）
      allow create: if isExamSubmitAllowedUser()
        && request.resource.data.submittedByEmail == request.auth.token.email
        && request.resource.data.locked == examCampaignLockedByDefault(request.resource.data.campaignId);
      // 公開填報（免登入）：僅在公開開關啟用時，允許匿名寫入
      allow create: if isExamPublicSubmitEnabled()
        && request.auth == null
        && request.resource.data.submittedByEmail == 'public'
        && request.resource.data.locked == examCampaignLockedByDefault(request.resource.data.campaignId)
        && request.resource.data.className is string
        && request.resource.data.className.size() > 0;
      // 導師修改：
      // - 活動預設鎖定=true：僅在已解鎖狀態下，且修改後需重新鎖定
      // - 活動預設鎖定=false：允許在未鎖定狀態下更新（仍需維持 locked=false）
      allow update: if isExamSubmitAllowedUser()
        && resource.data.locked == false
        && request.resource.data.locked == examCampaignLockedByDefault(resource.data.campaignId)
        && request.resource.data.submittedByEmail == request.auth.token.email
        && request.resource.data.campaignId == resource.data.campaignId
        && request.resource.data.className == resource.data.className;
      // 管理者解鎖/管理（可將 locked 改 false）
      allow update: if isEduTrackAdmin()
        && request.resource.data.campaignId == resource.data.campaignId
        && request.resource.data.className == resource.data.className;
      // 公開填報免登入：允許更新「原本就是 public 且未鎖定」的資料（避免匿名覆寫導師/管理者提報）
      allow update: if isExamPublicSubmitEnabled()
        && request.auth == null
        && resource.data.submittedByEmail == 'public'
        && request.resource.data.submittedByEmail == 'public'
        && resource.data.locked == false
        && request.resource.data.locked == examCampaignLockedByDefault(resource.data.campaignId)
        && request.resource.data.campaignId == resource.data.campaignId
        && request.resource.data.className == resource.data.className;
      allow delete: if isEduTrackAdmin();
    }
    // 段考提報進度（僅班級／時間；公開可讀，不含 students／不含提報主檔個資）
    match /edutrack_exam_submit_progress/{id} {
      allow read: if true;
      allow create: if isExamSubmitAllowedUser()
        && request.resource.data.keys().hasOnly(['campaignId', 'className', 'lastSubmittedAt'])
        && request.resource.data.campaignId is string
        && request.resource.data.className is string
        && request.resource.data.campaignId.size() > 0
        && request.resource.data.className.size() > 0;
      allow create: if isExamPublicSubmitEnabled()
        && request.auth == null
        && request.resource.data.keys().hasOnly(['campaignId', 'className', 'lastSubmittedAt'])
        && request.resource.data.campaignId is string
        && request.resource.data.className is string
        && request.resource.data.campaignId.size() > 0
        && request.resource.data.className.size() > 0;
      allow update: if isExamSubmitAllowedUser()
        && resource.data.campaignId == request.resource.data.campaignId
        && resource.data.className == request.resource.data.className
        && request.resource.data.keys().hasOnly(['campaignId', 'className', 'lastSubmittedAt']);
      // 教學組：自提報主檔補寫進度列（舊資料回填）
      allow create, update: if isEduTrackAdmin()
        && request.resource.data.keys().hasOnly(['campaignId', 'className', 'lastSubmittedAt'])
        && request.resource.data.campaignId is string
        && request.resource.data.className is string
        && request.resource.data.campaignId.size() > 0
        && request.resource.data.className.size() > 0;
      allow delete: if isEduTrackAdmin();
    }
    match /edutrack_allowed_users/{email} {
      allow read: if isEduTrackAdmin() || (isSignedIn() && request.auth.token.email == email);
      allow create, update, delete: if isEduTrackAdmin();
    }
    
    // （保留）若未來改回用 edutrack_calendar_settings，也能存取
    match /edutrack_calendar_settings/{docId} {
      allow read, write: if isEduTrackAllowedUser();
    }
    match /edutrack_budget_plans/{planId} {
      allow read, write: if isEduTrackAllowedUser();
      match /ledger_entries/{entryId} {
        allow read, write: if isEduTrackAllowedUser();
      }
    }
    match /edutrack_budget_plan_advances/{id} {
      allow read, write: if isEduTrackAllowedUser();
    }
    
    // =========================================================
    // 預設規則
    // =========================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

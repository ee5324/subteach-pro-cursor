# 是否啟用 Sandbox 模式（不需 Firebase / GAS 即可跑完整流程）
# VITE_SANDBOX=true

# Firebase（與其他系統共用同一專案即可，本系統僅用「帶前綴」的集合，不影響其他功能）
# 請填你現有專案的 Web 應用程式設定
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# 選填：Analytics measurementId（有填才會初始化 Analytics）
# VITE_FIREBASE_MEASUREMENT_ID=
# 集合名稱前綴（預設 edutrack_）→ 實際集合：edutrack_courses, edutrack_students 等
# 若自訂前綴，Firestore 規則裡的集合名需一致（見 firestore-rules-snippet.rules）
# VITE_FIREBASE_COLLECTION_PREFIX=edutrack_

# 選填：Google Apps Script Web App URL（附檔上傳、點名單/頒獎 Doc 仍使用 GAS）
# VITE_GAS_API_URL=
